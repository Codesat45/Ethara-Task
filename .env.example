# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=inventory_user
POSTGRES_PASSWORD=inventory_pass
POSTGRES_DB=inventory_db

# ─── Backend ──────────────────────────────────────────────────────────────────
# For Docker Compose, this is auto-constructed from postgres service
DATABASE_URL=postgresql://inventory_user:inventory_pass@postgres:5432/inventory_db

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-in-production

DEBUG=false

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-frontend.vercel.app

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
