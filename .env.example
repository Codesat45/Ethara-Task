# ═══════════════════════════════════════════════════════════════
# InvTrack — Docker Compose environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=invtrack_user
POSTGRES_PASSWORD=invtrack_pass
POSTGRES_DB=invtrack_db

# ── Backend ───────────────────────────────────────────────────
# Auto-constructed from the postgres service above.
# Override only if you want to use an external DB (e.g. Neon).
# DATABASE_URL=postgresql://invtrack_user:invtrack_pass@postgres:5432/invtrack_db

# Generate a strong secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-in-production-use-32-random-chars

DEBUG=false

# Extra CORS origins (comma-separated). localhost:3000 and localhost:5173
# are always included. Add your production frontend URL here.
EXTRA_ORIGINS=

# ── Frontend ──────────────────────────────────────────────────
# URL the browser uses to reach the API.
# With the nginx proxy (default): use /api/v1 (same-origin, no CORS).
# Without the proxy: use http://localhost:8000/api/v1
VITE_API_URL=http://localhost:8000/api/v1
